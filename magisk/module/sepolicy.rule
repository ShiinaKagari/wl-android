# wl-android SELinux 策略
# 允许 untrusted_app 连接 socket_device 类型的 Unix 套接字
allow untrusted_app socket_device:sock_file write;
allow untrusted_app socket_device:unix_stream_socket connectto;

# 允许 socketd (ksu 域) 管理 socket
allow ksu socket_device:sock_file create_file_perms;
allow ksu socket_device:dir { search write add_name };
