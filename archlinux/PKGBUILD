# Maintainer: wl-android maintainers <maintainers@wl-android.dev>
# Contributor: wl-android
# Arch Linux 包: wl-android-land (容器侧组件)
pkgname=wl-android-land
pkgver=0.1.0
pkgrel=1
pkgdesc="wl-android: Wayland→Android DMA-BUF 零拷贝转发 (容器后端插件)"
arch=('x86_64')
url="https://github.com/wl-android/wl-android"
license=('MIT')
depends=(
    'wlroots>=0.17'
    'libdrm>=2.4.110'
    'vulkan-icd-loader'
)
makedepends=(
    'cargo'
    'rust>=1.85'
    'pkg-config'
    'wayland-protocols'
)
source=("$pkgname-$pkgver.tar.gz::https://github.com/wl-android/wl-android/archive/v$pkgver.tar.gz")
sha256sums=('SKIP')

build() {
    cd "$srcdir/$pkgname-$pkgver"

    # 构建容器侧组件 (x86_64-linux-gnu)
    cargo build \
        --target x86_64-unknown-linux-gnu \
        --release \
        -p land-common \
        -p land \
        -p landd

    # 构建 land-app 原生库 (Android aarch64)
    # 需要 Android NDK + cargo-ndk
    if command -v cargo-ndk &>/dev/null; then
        cargo ndk -t arm64-v8a build --release -p land-common
    fi
}

package() {
    cd "$srcdir/$pkgname-$pkgver"

    # wlroots 后端插件
    install -Dm755 \
        "target/x86_64-unknown-linux-gnu/release/libland_wlroots.so" \
        "$pkgdir/usr/lib/wlroots/libland_wlroots.so"

    # 守护进程（可选，容器内也可运行 landd 用于调试）
    install -Dm755 \
        "target/x86_64-unknown-linux-gnu/release/landd" \
        "$pkgdir/usr/bin/landd"

    # 配置文件模板
    install -Dm644 \
        "debian/control" \
        "$pkgdir/usr/share/doc/$pkgname/control"

    # LICENSE (MIT, in README)
    install -Dm644 \
        "README.md" \
        "$pkgdir/usr/share/doc/$pkgname/README.md"
}
