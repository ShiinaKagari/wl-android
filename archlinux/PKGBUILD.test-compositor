# Maintainer: wl-android maintainers <maintainers@wl-android.dev>
# Arch Linux 包: wl-android-test-compositor (最小演示合成器)
pkgname=wl-android-test-compositor
pkgver=0.1.0
pkgrel=1
pkgdesc="wl-android 测试合成器: 最小 wlroots 合成器 + DMA-BUF 转发演示"
arch=('x86_64')
url="https://github.com/wl-android/wl-android"
license=('MIT')
depends=(
    'wlroots>=0.17'
    'libdrm'
    'wl-android-land'
)
makedepends=('gcc' 'pkg-config')
source=("$pkgname-$pkgver.tar.gz::https://github.com/wl-android/wl-android/archive/v$pkgver.tar.gz")
sha256sums=('SKIP')

build() {
    cd "$srcdir/$pkgname-$pkgver/test-compositor"
    make
}

package() {
    cd "$srcdir/$pkgname-$pkgver/test-compositor"
    install -Dm755 wl-android-compositor "$pkgdir/usr/bin/wl-android-compositor"
}
